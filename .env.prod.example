# Project Config
PROJECT_NAME="University Portal Backend"
ENV="production"
DEBUG=false
API_V1_STR="/api/v1"

# CORS Configuration (JSON array of strings)
# Adjust these URLs to match your production domain names
BACKEND_CORS_ORIGINS='["https://ktcn.edu.vn", "https://admin.ktcn.edu.vn"]'

# PostgreSQL Database Configuration
# Enforce a strong password in production
POSTGRES_DB="university_cms"
POSTGRES_USER="postgres_prod_user"
POSTGRES_PASSWORD="change_me_to_a_very_strong_password_123"

# Redis Configuration
# Enforce a strong password for Redis in production
REDIS_PASSWORD="change_me_to_a_secure_redis_password_456"

# Security Config
# Generate a secure 32-byte hex string in production: openssl rand -hex 32
SECRET_KEY="generate_and_paste_a_secure_32_byte_hex_string_here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Logging
LOG_LEVEL="INFO"
LOG_FILE_PATH="logs/app.log"

# MinIO / S3 Storage Configuration
MINIO_ACCESS_KEY="minio_prod_admin"
MINIO_SECRET_KEY="change_me_to_a_secure_minio_password_789"
MINIO_BUCKET="university-media"

# AI Config
GEMINI_API_KEY="your-gemini-api-key-here"
AI_PROVIDER="omniroute"
AI_API_KEY="sk-omniroute-secret-key"
AI_DEFAULT_MODEL="gemini-2.5-flash"

# Translation Config (Local AI Model)
TRANSLATION_MODEL_NAME="facebook/nllb-200-distilled-1.3B"
TRANSLATION_DEVICE="auto"
